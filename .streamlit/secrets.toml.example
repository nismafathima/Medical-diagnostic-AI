# Copy this file to .streamlit/secrets.toml (same folder name, drop ".example")
# and NEVER commit the real secrets.toml to version control — it's already
# listed in .gitignore.
#
# This is the recommended way to supply your OpenAI key for a deployed app
# (Streamlit Community Cloud reads this file automatically). For local dev,
# the sidebar text input or the OPENAI_API_KEY environment variable both
# work too — see .env.example.

OPENAI_API_KEY = "sk-your-key-here"
